# --- LLM (optional but recommended for natural answers) ---
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Embeddings ---
EMBEDDING_PROVIDER=sentence_transformers
ST_MODEL=BAAI/bge-m3
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Paths ---
KB_PATH=knowledge_base
CHROMA_PATH=knowledge_base/vector_store_chroma
COLLECTION_NAME=knowledge_base

# --- Retrieval / Guardrails ---
TOP_K=6
MAX_CONTEXT_CHARS=8000

MIN_SIMILARITY=0.55
MIN_KEYWORD_OVERLAP=0.20
HIGH_SIMILARITY_OVERRIDE=0.70

# --- App ---
HOST=0.0.0.0
PORT=8000
