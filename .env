# --- LLM (optional but recommended for natural answers) ---
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o

GITHUB_TOKEN=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

# Add this new env var:
OPENAI_BASE_URL=https://models.github.ai/inference
GITHUB_API_VERSION=2022-11-28

## =========================
# Embeddings (local, fast)
# =========================
EMBEDDING_PROVIDER=sentence_transformers
ST_MODEL=BAAI/bge-small-en-v1.5

# =========================
# Paths / Chroma
# =========================
KB_PATH=knowledge_base
CHROMA_PATH=knowledge_base/vector_store_chroma

# This MUST match your latest ingest output collection:
COLLECTION_NAME=kb_bge_small

# =========================
# Retrieval / Guardrails (fast RAG)
# =========================
TOP_K=3
MAX_CONTEXT_CHARS=2500

# Keep your strictness; tune if refusals become too frequent
MIN_SIMILARITY=0.55
CLARIFY_MIN_SIMILARITY=0.25

# =========================
# Chunking
# =========================
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# =========================
# Optional: Two-stage RAG + reranker
# Only works if you implemented reranker code.
# =========================
RETRIEVE_TOP_N=10
USE_RERANKER=false
RERANK_KEEP_K=3
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MAX_DOC_CHARS=900

# =========================
# App
# =========================
HOST=0.0.0.0
PORT=8000

LLM_MAX_TOKENS=220
LLM_TEMPERATURE=0.2
